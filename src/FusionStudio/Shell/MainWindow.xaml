<Window x:Class="FusionStudio.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FusionStudio.ViewModels"
        xmlns:views="clr-namespace:FusionStudio.Views"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}"
        Width="1560"
        Height="940"
        MinWidth="1240"
        MinHeight="780"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DeviceOverviewViewModel}">
            <views:DeviceOverviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConfigurationWorkbenchViewModel}">
            <views:ConfigurationWorkbenchView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AlarmConfigurationViewModel}">
            <views:AlarmConfigurationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:InterlockManagementViewModel}">
            <views:InterlockManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ModuleWorkbenchViewModel}">
            <views:ModuleWorkbenchView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:IoMonitorViewModel}">
            <views:IoMonitorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RuntimeDiagnosticsViewModel}">
            <views:RuntimeDiagnosticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:LogsWorkbenchViewModel}">
            <views:LogsWorkbenchView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ControlConsoleViewModel}">
            <views:ControlConsoleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:DebugAssistantViewModel}">
            <views:DebugAssistantView />
        </DataTemplate>
    </Window.Resources>
    <Grid Background="#E8EDF3">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1A2633"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#F7FAFC"
                               Text="{Binding ApplicationTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="#D9E2EC"
                               Text="{Binding ShellSubtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,6"
                        Background="#27384B"
                        CornerRadius="14"
                        VerticalAlignment="Center">
                    <TextBlock Foreground="#EAF2F8"
                               FontWeight="SemiBold"
                               Text="{Binding Layout.TopAreaTitle}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="18,18,10,18"
                    Background="#F6F8FB"
                    CornerRadius="18"
                    Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Navigation.Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Margin="0,0,0,10"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#334E68"
                                               Text="{Binding Title}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,0,8"
                                                        Padding="14,10"
                                                        HorizontalContentAlignment="Left"
                                                        Background="White"
                                                        BorderBrush="#C5D1DD"
                                                        BorderThickness="1"
                                                        Click="OnNavigationItemClick">
                                                    <StackPanel>
                                                        <TextBlock FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#102A43"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#486581"
                                                                   Text="{Binding Description}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,18,10,18"
                    Padding="22"
                    Background="White"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#102A43"
                                   Text="{Binding CurrentViewTitle}" />
                        <TextBlock Margin="0,6,0,18"
                                   FontSize="12"
                                   Foreground="#627D98"
                                   Text="{Binding Layout.WorkspaceAreaTitle}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="16">
                        <ContentControl Margin="20"
                                        Content="{Binding CurrentViewModel}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Margin="10,18,18,18"
                    Background="#F4F7FB"
                    CornerRadius="18"
                    Padding="18">
                <StackPanel>
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#102A43"
                               Text="模块摘要" />
                    <TextBlock Margin="0,6,0,14"
                               FontSize="12"
                               Foreground="#627D98"
                               Text="右侧面板用于快速查看设备模块树与当前工具域的工程入口。" />

                    <ItemsControl ItemsSource="{Binding Modules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="White"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="#102A43"
                                                   Text="{Binding ModuleName}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="#627D98">
                                            <Run Text="{Binding ModuleType}" />
                                            <Run Text=" / " />
                                            <Run Text="{Binding ModuleState}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#D9E2EC"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <TextBlock FontWeight="SemiBold"
                           Foreground="#334E68"
                           Text="{Binding Layout.FooterAreaTitle}" />

                <ItemsControl Grid.Column="1"
                              Margin="12,0,0,0"
                              ItemsSource="{Binding Status.Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="8,2"
                                    Background="#F8FBFD"
                                    CornerRadius="10">
                                <TextBlock Foreground="#334E68">
                                    <Run FontWeight="SemiBold" Text="{Binding Label}" />
                                    <Run Text=": " />
                                    <Run Text="{Binding Value}" />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           HorizontalAlignment="Right"
                           Foreground="#486581"
                           Text="{Binding Status.Message}" />
            </Grid>
        </Border>
    </Grid>
</Window>

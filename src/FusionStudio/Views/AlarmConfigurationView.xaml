<UserControl x:Class="FusionStudio.Views.AlarmConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Margin="0,10,0,0"
                   FontSize="13"
                   Text="{Binding Description}" />

        <Border Margin="0,16,0,0"
                Padding="14"
                Background="#EEF4FA"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#334E68"
                               Text="上下文头部" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#102A43"
                               Text="{Binding Context.EquipmentName}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#486581">
                        <Run Text="{Binding Context.ModuleContext.ModuleName}" />
                        <Run Text=" / " />
                        <Run Text="{Binding Context.ModuleContext.ModuleType}" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#334E68"
                               Text="当前工具域" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#102A43"
                               Text="{Binding Context.ToolDomain}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#486581"
                               Text="{Binding Context.ModuleContext.ModuleState}" />
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Margin="0,18,0,0"
                      ItemsSource="{Binding Modules}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="12"
                            Background="#F8FAFC"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding ModuleName}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#486581"
                                       Text="{Binding ModuleState}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Margin="0,18,0,0"
                Padding="14"
                Background="#FFF6E0"
                CornerRadius="12">
            <TextBlock Foreground="#7C5E10"
                       Text="{Binding Hint}" />
        </Border>
    </StackPanel>
</UserControl>

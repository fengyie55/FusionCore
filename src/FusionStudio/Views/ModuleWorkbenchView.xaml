<UserControl x:Class="FusionStudio.Views.ModuleWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <HierarchicalDataTemplate x:Key="EngineeringTreeNodeTemplate"
                                  ItemsSource="{Binding Children}">
            <StackPanel Margin="0,2,0,2">
                <TextBlock FontWeight="SemiBold"
                           Foreground="#102A43"
                           Text="{Binding Title}" />
                <TextBlock FontSize="11"
                           Foreground="#627D98"
                           Text="{Binding Summary}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,10,0,0"
                       FontSize="13"
                       Text="{Binding Description}" />
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Padding="14"
                    Background="#F8FAFC"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#102A43"
                                   Text="工程树" />
                        <TextBlock Margin="0,4,0,12"
                                   FontSize="12"
                                   Foreground="#627D98"
                                   Text="模块工作台按设备节点和模块节点展开工具域，后续各类工程工具都会挂在这棵树上。" />
                    </StackPanel>

                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding EngineeringNodes}"
                              ItemTemplate="{StaticResource EngineeringTreeNodeTemplate}"
                              Background="Transparent"
                              BorderThickness="0">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Padding" Value="4" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="10,0,0,0"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Modules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    Background="#F8FAFC"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding ModuleName}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="#486581">
                                        <Run Text="{Binding ModuleType}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding ModuleState}" />
                                    </TextBlock>
                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="12"
                                               Foreground="#627D98"
                                               Text="{Binding Summary}" />
                                    <ItemsControl Margin="0,8,0,0"
                                                  ItemsSource="{Binding ToolEntries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10,8"
                                                        Background="White"
                                                        BorderBrush="#D9E2EC"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="#243B53"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#486581"
                                                                   Text="{Binding Summary}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Padding="14"
                Background="#FFF6E0"
                CornerRadius="12">
            <TextBlock Foreground="#7C5E10"
                       Text="{Binding Hint}" />
        </Border>
    </Grid>
</UserControl>

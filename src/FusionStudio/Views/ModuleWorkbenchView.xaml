<UserControl x:Class="FusionStudio.Views.ModuleWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Margin="0,10,0,0"
                   FontSize="13"
                   Text="{Binding Description}" />
        <ItemsControl Margin="0,18,0,0"
                      ItemsSource="{Binding Modules}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="14"
                            Background="#F8FAFC"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="{Binding ModuleName}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#486581">
                                <Run Text="{Binding ModuleType}" />
                                <Run Text=" / " />
                                <Run Text="{Binding ModuleState}" />
                            </TextBlock>
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="#627D98"
                                       Text="{Binding Summary}" />
                            <ItemsControl Margin="0,8,0,0"
                                          ItemsSource="{Binding ToolEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="10,8"
                                                Background="White"
                                                BorderBrush="#D9E2EC"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Foreground="#243B53"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Title}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           FontSize="12"
                                                           Foreground="#486581"
                                                           Text="{Binding Summary}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Border Margin="0,18,0,0"
                Padding="14"
                Background="#FFF6E0"
                CornerRadius="12">
            <TextBlock Foreground="#7C5E10"
                       Text="{Binding Hint}" />
        </Border>
    </StackPanel>
</UserControl>

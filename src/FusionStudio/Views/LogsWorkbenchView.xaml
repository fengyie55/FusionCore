<UserControl x:Class="FusionStudio.Views.LogsWorkbenchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="{Binding Title}" />
        <TextBlock Margin="0,10,0,0"
                   FontSize="13"
                   Text="{Binding Description}" />

        <Border Margin="0,18,0,0"
                Padding="14"
                Background="#FDECEC"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Foreground="#8A1C1C"
                           Text="{Binding Hint}" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="#8A1C1C"
                           Text="{Binding Summary.SummaryText}" />
            </StackPanel>
        </Border>
        <ItemsControl Margin="0,16,0,0"
                      ItemsSource="{Binding Summary.Entries}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="12"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="#334E68"
                                       Text="{Binding Timestamp}" />
                            <TextBlock Grid.Column="1"
                                       Foreground="#8A1C1C"
                                       Text="{Binding Level}" />
                            <TextBlock Grid.Column="2"
                                       Foreground="#486581"
                                       Text="{Binding Category}" />
                            <StackPanel Grid.Column="3">
                                <TextBlock Foreground="#102A43"
                                           Text="{Binding Message}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="#627D98"
                                           Text="{Binding Source}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>

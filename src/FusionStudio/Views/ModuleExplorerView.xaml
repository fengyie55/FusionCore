<UserControl x:Class="FusionStudio.Views.ModuleExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="24" Background="White">
        <StackPanel>
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding Title}" />
            <TextBlock Margin="0,12,0,0" FontSize="14" Text="{Binding Description}" />
        </StackPanel>
    </Border>
</UserControl>

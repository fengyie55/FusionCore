<Application x:Class="FusionUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:FusionUI.Views"
             xmlns:viewModels="clr-namespace:FusionUI.ViewModels"
             StartupUri="Shell/MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:OverviewViewModel}">
            <views:OverviewView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:OperatorViewModel}">
            <views:OperatorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EngineerViewModel}">
            <views:EngineerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RuntimeViewModel}">
            <views:RuntimeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:EquipmentViewModel}">
            <views:EquipmentView />
        </DataTemplate>
    </Application.Resources>
</Application>

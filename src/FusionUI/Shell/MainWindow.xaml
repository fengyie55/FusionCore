<Window x:Class="FusionUI.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding ApplicationTitle}"
        Width="1360"
        Height="860"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="84" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#12324A"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding ApplicationTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="#D6E4F0"
                               Text="{Binding ShellSubtitle}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        Background="#1A4868"
                        CornerRadius="14">
                    <TextBlock Foreground="#EAF4FB"
                               FontWeight="SemiBold"
                               Text="{Binding Layout.TopAreaTitle}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="20,20,12,20"
                    Padding="16"
                    Background="#E7EDF3"
                    CornerRadius="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Navigation.Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Margin="0,0,0,10"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="#365164"
                                               Text="{Binding Title}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,0,8"
                                                        Padding="14,10"
                                                        HorizontalContentAlignment="Left"
                                                        Background="White"
                                                        BorderBrush="#C6D4E1"
                                                        BorderThickness="1"
                                                        Click="OnNavigationItemClick">
                                                    <StackPanel>
                                                        <TextBlock FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1F2933"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#52606D"
                                                                   Text="{Binding Description}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,20,20,20"
                    Padding="22"
                    Background="White"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#172B3A"
                                   Text="{Binding CurrentViewTitle}" />
                        <TextBlock Margin="0,6,0,18"
                                   FontSize="12"
                                   Foreground="#5B7083"
                                   Text="{Binding Layout.WorkspaceAreaTitle}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F8FAFC"
                            BorderBrush="#D9E2EC"
                            BorderThickness="1"
                            CornerRadius="14">
                        <ContentControl Margin="20"
                                        Content="{Binding CurrentViewModel}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#E5EDF4"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock FontWeight="SemiBold"
                           Foreground="#365164"
                           Text="{Binding Layout.FooterAreaTitle}" />
                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           Foreground="#52606D"
                           Text="{Binding FooterMessage}" />
            </Grid>
        </Border>
    </Grid>
</Window>
